#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
IMAGE_NAME="api-resources-test-php"

docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d --wait
docker build -q -t "$IMAGE_NAME" "$SCRIPT_DIR" > /dev/null

docker run --rm \
    -v "$PROJECT_DIR:/app" \
    -w /app/tests \
    --network tests_default \
    -e DB_HOST=mysql \
    -e DB_PORT=3306 \
    "$IMAGE_NAME" \
    php vendor/phpunit/phpunit/phpunit "$@"
